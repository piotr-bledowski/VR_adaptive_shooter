# ── Override parent .gitignore (parent ignores ProjectSettings/ too broadly) ───
!ProjectSettings/

# ── Unity generated ────────────────────────────────────────────────────────────
Library/
Temp/
obj/
Build/
Builds/
Logs/
MemoryCaptures/
UserSettings/
TempAssembly.dll
MGU_project_BurstDebugInformation_DoNotShip/

# Unity crash / OS junk
crashlytics-build.properties
*.DS_Store
Thumbs.db

# ── Log files ──────────────────────────────────────────────────────────────────
*.log
*.log.*

# ── Android builds ─────────────────────────────────────────────────────────────
*.apk
*.aab

# ── Python environments ────────────────────────────────────────────────────────
venv/
venv_ml/
.venv/
env/
__pycache__/
*.pyc
*.pyo

# ── ML model weights & training outputs ───────────────────────────────────────
results/
*.pt
*.onnx

# ── PowerShell scripts ─────────────────────────────────────────────────────────
*.ps1

# ── Documentation ──────────────────────────────────────────────────────────────
docs/

# ── Archived scenes (Seal, TestScene) and their assets ────────────────────────
Assets/Archive/

# ── IDE / Editor metadata ──────────────────────────────────────────────────────
.vs/
.vscode/
*.csproj
*.sln
*.suo
*.user
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db

# ── JetBrains Rider ────────────────────────────────────────────────────────────
.idea/
ExportedObj/

# ── Node / npm (if ever used) ──────────────────────────────────────────────────
node_modules/
